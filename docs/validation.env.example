# Shared validation environment template for Sentinel Flow live signoff.
# Copy the values you need into your shell or deployment secret store before
# running Goal 5 through Goal 10 validation commands.

# Shared site / report configuration
VALIDATION_SITE_URL=http://127.0.0.1:3000
VALIDATION_REPORT_PATH=artifacts/goal-validation.json
VALIDATION_USER_ID=

# Goal 10 launch-audit controls
VALIDATION_ROUTE_PATHS=/,/dashboard,/alerts,/history,/settings,/billing
VALIDATION_INCLUDE_GOALS=5,6,7,8,9
VALIDATION_RUN_WEB_TEST=true
VALIDATION_RUN_WEB_BUILD=true

# Engine / Goal 5-8 runtime
ENGINE_STATUS_URL=http://127.0.0.1:8080/healthz
VALIDATION_EXPECT_READY=true
VALIDATION_EXPECT_RULE_SOURCE=supabase-alert-rules
VALIDATION_EXPECT_SYMBOLS=BTCUSDT,ETHUSDT
VALIDATION_EXPECT_TIMEFRAMES=1m,5m,15m
VALIDATION_POLL_INTERVAL_MS=1000
VALIDATION_POLL_TIMEOUT_MS=30000

# Goal 7 proof contract expectations
VALIDATION_EXPECT_MEDIA_TYPES=image/svg+xml,image/png
VALIDATION_EXPECT_WIDTH=720
VALIDATION_EXPECT_HEIGHT=960

# Supabase / Goal 6-9
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# Telegram / Goal 8
TELEGRAM_BOT_TOKEN=
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=
VALIDATION_API_KEY=
VALIDATION_TRIGGER_ALERT=true
VALIDATION_TRIGGER_MARKET=BTCUSDT
VALIDATION_TRIGGER_SIDE=buy
VALIDATION_TRIGGER_TIMEFRAME=1m
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Stripe / Goal 9
STRIPE_SECRET_KEY=
STRIPE_SCOUT_PRICE_ID=
STRIPE_FOUNDING_ACCESS_PRICE_ID=
STRIPE_SENTINEL_PRO_PRICE_ID=
STRIPE_ALPHA_STREAM_PRICE_ID=
VALIDATION_EXPECT_PLAN_KEYS=scout,founding_access,sentinel_pro
